#!/usr/bin/env bash
set -euo pipefail

resolved_script_dir() {
  local source_path
  local dir_path
  local link_target
  source_path="${BASH_SOURCE[0]}"

  while [ -L "$source_path" ]; do
    dir_path="$(cd -P "$(dirname "$source_path")" && pwd)"
    link_target="$(readlink "$source_path")"
    case "$link_target" in
      /*) source_path="$link_target" ;;
      *) source_path="${dir_path}/${link_target}" ;;
    esac
  done

  cd -P "$(dirname "$source_path")" && pwd
}

main() {
  : "$(resolved_script_dir)"
  exec python3 - "$@" <<'PY'

import json
import math
import os
import re
import sys
from pathlib import Path

PRICE_PER_MILLION = {
    "glm-5.2": {"input": 1.40, "cache_read": 0.26, "output": 4.40},
    "glm-4.6v": {"input": 0.30, "cache_read": 0.05, "output": 0.90},
    "glm-5-turbo": None,
}


def fail(message: str, code: int = 1) -> None:
    print(f"albion-metrics: {message}", file=sys.stderr)
    raise SystemExit(code)


def usage_error(message: str) -> None:
    fail(f"{message}; usage: albion-metrics --result <file> [--lane plan|api] [--session <id>] [--state-dir <dir>] [--task-label <text>] [--pretty]", 64)


def read_option(argv: list[str], index: int, option: str) -> tuple[str, int]:
    if index + 1 >= len(argv):
        usage_error(f"{option} requires a value")
    value = argv[index + 1]
    if value == "":
        usage_error(f"{option} requires a non-empty value")
    return value, index + 2


def parse_args(argv: list[str]) -> dict[str, str | bool]:
    args: dict[str, str | bool] = {"pretty": False}
    index = 0
    while index < len(argv):
        arg = argv[index]
        match arg:
            case "--result" | "--lane" | "--session" | "--state-dir" | "--task-label":
                value, index = read_option(argv, index, arg)
                args[arg[2:].replace("-", "_")] = value
            case "--pretty":
                args["pretty"] = True
                index += 1
            case "--help" | "-h":
                usage_error("help requested")
            case _:
                usage_error(f"unknown argument {arg}")
    if "result" not in args:
        usage_error("--result is required")
    return args


def read_result(path_text: str) -> dict[str, object]:
    path = Path(path_text)
    try:
        raw = path.read_text(encoding="utf-8")
    except OSError as error:
        fail(f"cannot read result file: {path}: {error}")
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as error:
        fail(f"invalid result json: {path}: {error.msg}")
    return payload if isinstance(payload, dict) else fail(f"result json is not an object: {path}")


def int_value(value: object) -> int | None:
    if isinstance(value, bool):
        return None
    if isinstance(value, int):
        return value
    return None


def number_value(value: object) -> int | float | None:
    if not isinstance(value, bool) and isinstance(value, int | float) and math.isfinite(value):
        return value
    return None


def string_value(value: object) -> str | None:
    return value if isinstance(value, str) else None


def token_value(source: dict[str, object], key: str) -> int:
    value = int_value(source.get(key))
    return value if value is not None and value >= 0 else 0


def model_tokens(result: dict[str, object]) -> dict[str, dict[str, int]]:
    raw_usage = result.get("modelUsage")
    if not isinstance(raw_usage, dict):
        return {}
    models: dict[str, dict[str, int]] = {}
    for slug, raw_model in raw_usage.items():
        if isinstance(slug, str) and isinstance(raw_model, dict):
            model = {str(key): value for key, value in raw_model.items()}
            models[slug] = {
                "input_tokens": token_value(model, "inputTokens"),
                "output_tokens": token_value(model, "outputTokens"),
                "cache_read_input_tokens": token_value(model, "cacheReadInputTokens"),
                "cache_creation_input_tokens": token_value(model, "cacheCreationInputTokens"),
            }
    return models


def usage_totals(models: dict[str, dict[str, int]]) -> dict[str, int]:
    totals = {"input_tokens": 0, "output_tokens": 0, "cache_read_input_tokens": 0, "cache_creation_input_tokens": 0}
    for usage in models.values():
        for key in totals:
            totals[key] += usage[key]
    return totals


def normalized_slug(slug: str) -> str:
    return re.sub(r"\[[^\]]+\]$", "", slug)


def api_cost(models: dict[str, dict[str, int]]) -> dict[str, object]:
    total = 0.0
    incomplete = False
    per_model: dict[str, dict[str, object]] = {}
    for slug, usage in models.items():
        lookup_slug = normalized_slug(slug)
        prices = PRICE_PER_MILLION.get(lookup_slug)
        if prices is None:
            incomplete = True
            per_model[slug] = {"normalized_model": lookup_slug, "usd": None, "pricing_incomplete": True}
            continue
        model_total = (
            (usage["input_tokens"] + usage["cache_creation_input_tokens"]) * prices["input"]
            + usage["cache_read_input_tokens"] * prices["cache_read"]
            + usage["output_tokens"] * prices["output"]
        ) / 1_000_000
        total += model_total
        per_model[slug] = {"normalized_model": lookup_slug, "usd": model_total, "pricing_incomplete": False}
    return {"lane": "api", "usd": None if incomplete else total, "pricing_incomplete": incomplete, "models": per_model}


def peak_multiplier() -> float:
    raw = os.environ.get("ALBION_PEAK_MULTIPLIER", "1")
    try:
        value = float(raw)
    except ValueError:
        fail(f"ALBION_PEAK_MULTIPLIER must be numeric, got {raw}")
    if not math.isfinite(value) or value < 0:
        fail(f"ALBION_PEAK_MULTIPLIER must be a non-negative finite number, got {raw}")
    return value


def plan_cost(turns: int) -> dict[str, object]:
    multiplier = peak_multiplier()
    return {"lane": "plan", "usd": None, "prompt_equivalents": (turns / 18) * multiplier, "turns_per_prompt": 18, "peak_multiplier": multiplier, "pricing_incomplete": False}


def read_state(state_dir: str, session_id: str | None) -> dict[str, object] | None:
    if session_id is None:
        return None
    path = Path(state_dir) / f"{session_id}.json"
    try:
        raw = path.read_text(encoding="utf-8")
    except OSError:
        return None
    try:
        state = json.loads(raw)
    except json.JSONDecodeError:
        return None
    return state if isinstance(state, dict) else None


def max_strikes(state: dict[str, object] | None) -> int | None:
    if state is None:
        return None
    strikes = state.get("strikes")
    if not isinstance(strikes, dict):
        return None
    counts = [value for value in strikes.values() if isinstance(value, int) and not isinstance(value, bool)]
    return max(counts) if counts else None


def gate_blocks(state: dict[str, object] | None) -> int | None:
    if state is None:
        return None
    gate = state.get("gate")
    if not isinstance(gate, dict):
        return None
    return int_value(gate.get("blocks"))


def last_test(state: dict[str, object] | None) -> dict[str, object] | None:
    if state is None:
        return None
    value = state.get("last_test")
    return value if isinstance(value, dict) else None


def workbench_present() -> bool:
    root = Path(os.environ.get("ALBION_WORKBENCH_ROOT", str(Path.cwd() / ".agent-workbench")))
    fable_root = root / "fable-mode"
    try:
        return fable_root.is_dir() and any(path.is_dir() for path in fable_root.iterdir())
    except OSError:
        return False


def resolve_lane(args: dict[str, str | bool]) -> str:
    lane = args.get("lane")
    if not isinstance(lane, str):
        lane = os.environ.get("ALBION_AUTH_LANE", "plan")
    match lane:
        case "plan" | "api":
            return lane
        case _:
            usage_error("lane must be plan or api")


def main() -> int:
    args = parse_args(sys.argv[1:])
    result = read_result(str(args["result"]))
    lane = resolve_lane(args)
    result_session_id = string_value(result.get("session_id"))
    session_arg = args.get("session")
    session_id = session_arg if isinstance(session_arg, str) else result_session_id
    state_dir_arg = args.get("state_dir")
    state_dir = (
        state_dir_arg if isinstance(state_dir_arg, str) else os.environ.get("ALBION_STATE_DIR", ".albion/state")
    )
    state = read_state(state_dir, session_id)
    turns = int_value(result.get("num_turns")) or 0
    models = model_tokens(result)
    record = {
        "schema": "albion-task-metrics/v1",
        "task_label": args.get("task_label") if isinstance(args.get("task_label"), str) else None,
        "session_id": session_id,
        "lane": lane,
        "duration_ms": int_value(result.get("duration_ms")),
        "num_turns": int_value(result.get("num_turns")),
        "usage": {"models": models, "totals": usage_totals(models)},
        "model_calls": {"turns": turns},
        "cost": api_cost(models) if lane == "api" else plan_cost(turns),
        "harness_reported_cost_usd": number_value(result.get("total_cost_usd")),
        "strikes": max_strikes(state),
        "gate_blocks": gate_blocks(state),
        "last_test": last_test(state),
        "workbench_present": workbench_present(),
        "is_error": result.get("is_error") if isinstance(result.get("is_error"), bool) else None,
        "terminal_reason": string_value(result.get("terminal_reason")),
    }
    if args["pretty"] is True:
        print(json.dumps(record, indent=2, sort_keys=True))
    else:
        print(json.dumps(record, sort_keys=True, separators=(",", ":")))
    return 0


raise SystemExit(main())
PY
}

main "$@"
