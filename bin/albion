#!/usr/bin/env bash
set -euo pipefail

warn_without_charter() {
  printf '%s\n' 'WARNING: running without the orchestration charter' >&2
}

resolve_script_dir() {
  local source_path
  local source_dir

  source_path="${BASH_SOURCE[0]}"
  while [ -h "$source_path" ]; do
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    case "$source_path" in
      /*) ;;
      *) source_path="${source_dir}/${source_path}" ;;
    esac
  done

  cd -P "$(dirname "$source_path")" && pwd
}

quote_argv() {
  local arg
  for arg in "$@"; do
    printf ' %q' "$arg"
  done
  printf '\n'
}

print_dry_run() {
  local token_state
  local charter_display

  if [ -n "${ANTHROPIC_AUTH_TOKEN+x}" ] && [ -n "${ANTHROPIC_AUTH_TOKEN}" ]; then
    token_state="***set***"
  else
    token_state="***unset***"
  fi

  if [ -n "$charter_path" ]; then
    charter_display="$charter_path"
  else
    charter_display="(none)"
  fi

  printf 'mode=%s\n' "$mode"
  printf 'auth_lane=%s\n' "${ALBION_AUTH_LANE:-}"
  printf 'anthropic_auth_token=%s\n' "$token_state"
  printf 'opus_model=%s\n' "${ANTHROPIC_DEFAULT_OPUS_MODEL:-}"
  printf 'sonnet_model=%s\n' "${ANTHROPIC_DEFAULT_SONNET_MODEL:-}"
  printf 'haiku_model=%s\n' "${ANTHROPIC_DEFAULT_HAIKU_MODEL:-}"
  printf 'charter=%s\n' "$charter_display"
  printf 'final_argv='
  quote_argv "${final_argv[@]}"
}

parse_args() {
  passthrough=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --vanilla)
        mode="vanilla"
        ;;
      --doctor)
        doctor_requested=1
        ;;
      --dry-run)
        dry_run=1
        ;;
      --albion-*)
        printf 'unknown Albion flag: %s\n' "$1" >&2
        exit 4
        ;;
      *)
        passthrough+=("$1")
        ;;
    esac
    shift
  done
}

source_albion_env() {
  if [ ! -f "$env_script" ]; then
    printf 'env sourcing failed: %s not found\n' "$env_script" >&2
    return 1
  fi

  # shellcheck source=env/albion-env.sh
  if ! . "$env_script"; then
    return 1
  fi
}

resolve_charter() {
  local candidate

  if [ "$mode" = "vanilla" ]; then
    charter_path=""
    return 0
  fi

  candidate="${ALBION_CHARTER:-${repo_root}/charter/ALBION.md}"
  if [ -f "$candidate" ]; then
    charter_path="$(cd -P "$(dirname "$candidate")" && pwd)/$(basename "$candidate")"
  else
    charter_path=""
    warn_without_charter
  fi
}

build_final_argv() {
  final_argv=("claude")

  if [ -n "$charter_path" ]; then
    final_argv+=("--append-system-prompt" "$(cat "$charter_path")")
  fi

  if [ "${#passthrough[@]}" -gt 0 ]; then
    final_argv+=("${passthrough[@]}")
  fi
}

main() {
  local script_dir
  local repo_root
  local env_script
  local doctor_script
  local mode
  local doctor_requested
  local dry_run
  local charter_path
  local -a passthrough
  local -a final_argv

  script_dir="$(resolve_script_dir)"
  repo_root="$(cd "${script_dir}/.." && pwd)"
  env_script="${repo_root}/env/albion-env.sh"
  doctor_script="${repo_root}/bin/albion-doctor"
  mode="default"
  doctor_requested=0
  dry_run=0
  charter_path=""
  passthrough=()
  final_argv=()

  parse_args "$@"

  if [ "$doctor_requested" -eq 1 ]; then
    if [ -x "$doctor_script" ]; then
      exec "$doctor_script" "${passthrough[@]}"
    fi
    printf '%s\n' 'doctor not installed yet' >&2
    exit 3
  fi

  if ! source_albion_env; then
    exit 1
  fi

  case "$mode" in
    default) export CLAUDE_AGENT_NAME="Albion" ;;
    vanilla) export CLAUDE_AGENT_NAME="Albion-vanilla" ;;
  esac

  resolve_charter
  build_final_argv

  if [ "$dry_run" -eq 1 ]; then
    print_dry_run
    return 0
  fi

  if ! command -v claude >/dev/null 2>&1; then
    printf '%s\n' 'claude binary not found on PATH; install Claude Code or add claude to PATH before running bin/albion.' >&2
    exit 2
  fi

  exec "${final_argv[@]}"
}

main "$@"
